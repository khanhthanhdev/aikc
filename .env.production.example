# =============================================================================
# VPS Production Environment — Local PostgreSQL, Qdrant & Infinity
# =============================================================================
# Copy this file to .env.production and fill in your real values.
# The Docker Compose stack overrides DATABASE_URL, QDRANT_URL, and
# INFINITY_EMBEDDING_URL with internal container network addresses,
# so you do NOT need to change those here.
# =============================================================================

# ── Site ─────────────────────────────────────────────────────────────────────
COMPOSE_SITE_URL="https://yourdomain.com"
COMPOSE_SITE_EMAIL="hello@yourdomain.com"

# ── PostgreSQL (local container) ─────────────────────────────────────────────
POSTGRES_USER="aikc"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
POSTGRES_DB="aikc"
# POSTGRES_PORT="5432"

# Operator-only: cloud source database for pg_dump bootstrap (remove after cutover)
# SYNC_SOURCE_DATABASE_URL="postgresql://user:password@source-host:5432/aikc?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET="CHANGE_ME_RANDOM_SECRET"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# ── Local Embedding (Infinity) ───────────────────────────────────────────────
# These are read by the compose stack; no need to change for local embedding.
USE_LOCAL_EMBEDDING="true"
# INFINITY_ENGINE="torch"
# INFINITY_MODEL_ID="sentence-transformers/all-MiniLM-L6-v2"
# INFINITY_EMBEDDING_DIMENSIONS="384"

# ── Qdrant (local container, internal-only) ────────────────────────────────
# Qdrant ports are NOT exposed to the host. Access only via Docker network.
# Admin: docker compose exec qdrant curl http://localhost:6333/collections
QDRANT_API_KEY="CHANGE_ME_QDRANT_API_KEY"
RAG_ENABLED="true"

# ── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_GENERATIVE_AI_API_KEY="your-google-ai-key"
ALIBABA_API_KEY="your-alibaba-api-key"

# ── External Services ────────────────────────────────────────────────────────
FIRECRAWL_API_KEY="fc-..."
RESEND_API_KEY="re_..."
SCREENSHOTONE_ACCESS_KEY="your-screenshotone-access-key"

# ── Amazon S3 (file uploads) ────────────────────────────────────────────────
S3_BUCKET="your-bucket-name"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"

# ── PostgREST ────────────────────────────────────────────────────────────────
# PGRST_DB_SCHEMA="public"
# PGRST_DB_ANON_ROLE="web_anon"
# COMPOSE_POSTGREST_URL="https://yourdomain.com/postgrest"

# ── Caddy ────────────────────────────────────────────────────────────────────
# CADDY_HTTP_PORT="80"

# ── Email Publishing ─────────────────────────────────────────────────────────
PUBLISH_SUBMITTER_EMAILS="true"

# ── Optional: Analytics & Payments (uncomment if used) ───────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="yourdomain.com"
# NEXT_PUBLIC_PLAUSIBLE_HOST="https://plausible.io"
# PLAUSIBLE_API_KEY="your-plausible-api-key"
# NEXT_PUBLIC_POSTHOG_HOST="https://us.posthog.com"
# NEXT_PUBLIC_POSTHOG_API_KEY="your-posthog-api-key"
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_SIGNING_SECRET="whsec_..."
# STRIPE_PRODUCT_IDS="prod_..."
# BEEHIIV_API_KEY="your-beehiiv-api-key"
# BEEHIIV_PUBLICATION_ID="your-beehiiv-publication-id"
