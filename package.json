{
  "name": "aikc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "email": "cp .env ./node_modules/react-email/dist/preview && email dev",
    "dev": "next dev -p 5175",
    "start": "next start -p 5175",
    "build": "SKIP_ENV_VALIDATION=1 next build",
    "lint": "bun biome lint --apply .",
    "check": "ultracite check",
    "format": "bun biome format --organize-imports-enabled --write .",
    "db:generate": "prisma generate --no-hints",
    "db:studio": "prisma studio",
    "db:push": "prisma db push --skip-generate",
    "db:reset": "prisma migrate reset --skip-seed && prisma db push --skip-generate",
    "db:bootstrap:dev": "bash ./scripts/bootstrap-postgres.sh dev",
    "db:bootstrap:vps": "bash ./scripts/bootstrap-postgres.sh vps",
    "db:verify:sync": "bash ./scripts/bootstrap-postgres.sh verify",
    "qdrant:setup": "bun run scripts/setup-qdrant.ts",
    "qdrant:reset": "bun run scripts/setup-qdrant.ts --force",
    "qdrant:test": "bun run scripts/test-qdrant-search.ts",
    "qdrant:drift": "bun run scripts/check-qdrant-drift.ts",
    "qdrant:clear-cache": "bun run scripts/clear-semantic-cache.ts",
    "import:ai-tools": "bun run scripts/import-ai-study-tools.ts",
    "related-tools:populate": "bun run scripts/populate-related-tools.ts",
    "icons": "bun run scripts/build-icons.ts",
    "prebuild": "bun run icons",
    "postinstall": "bun run db:generate",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/react": "^3.0.113",
    "@aws-sdk/client-s3": "^3.685.0",
