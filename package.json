    "@mdx-js/react": "^3.1.0",
    "@mendable/firecrawl-js": "^1.7.2",
    "@next/mdx": "16.2.5",
    "@prisma/client": "6",
    "@qdrant/js-client-rest": "^1.16.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
